<section class="w-full bg-bg-soft border-b border-border-soft">
  <div class="max-w-7xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-10 items-center">

    <!-- LEFT -->
    <div class="space-y-6">
      <h1 class="text-4xl md:text-5xl font-semibold text-text leading-tight">
        Controla tu inventario <br />
        sin hojas de cálculo
      </h1>

      <p class="text-text-muted text-lg">
        Gestiona productos, ventas y stock en tiempo real
      </p>

      <div class="flex gap-4">
        <a
          href="#"
          class="bg-btn-primary text-text-inverse px-6 py-2 rounded-full hover:bg-btn-primary-hover transition"
        >
          empieza gratis
        </a>

        <a
          href="#"
          class="bg-btn-secondary text-text px-6 py-2 rounded-full hover:bg-btn-secondary-hover transition"
        >
          ver demo
        </a>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="flex justify-center">
      <div class="w-[320px] h-60 border-2 border-border rounded-xl p-4 flex flex-col gap-3">
        
        <div class="flex gap-3">
          <div class="flex-1 h-10 border border-border rounded"></div>
          <div class="flex-1 h-10 border border-border rounded"></div>
          <div class="flex-1 h-10 border border-border rounded"></div>
        </div>

        <div class="flex gap-3 flex-1">
          <div class="w-16 border border-border rounded"></div>
          <div class="flex-1 border border-border rounded"></div>
        </div>

        <div class="h-10 border border-border rounded"></div>
      </div>
    </div>

  </div>
</section>